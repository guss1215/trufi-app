# Cochabamba metropolitan area.
#
# This bbox is the metropolitan area used by the GTFS builder
# (trufi-app/tools/gtfs-bolivia-cochabamba/index.ts BOUNDING_BOX).
# It is intentionally larger than the city-center example shown in
# trufi-pbf-extractor's README — the GTFS pipeline needs the wider area
# to capture suburban routes.
#
# Format expected by trufi-pbf-extractor: west,south,east,north
CITY_NAME=cochabamba
BBOX=-66.440262,-17.709721,-65.577835,-17.261759
GEOFABRIK_URL_PATH=/south-america/bolivia-latest.osm.pbf
