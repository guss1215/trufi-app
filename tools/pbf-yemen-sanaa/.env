# Sana'a (Amanat Al Asimah), Yemen.
#
# This bbox is the area used by the GTFS builder
# (trufi-app/tools/gtfs-yemen-sanaa/index.ts BOUNDING_BOX) and the map-tile
# generator (trufi-app/tools/mbtiles-yemen-sanaa). It covers the city and its
# immediate surroundings — wide enough to capture the bus network mapped in OSM.
#
# Format expected by trufi-pbf-extractor: west,south,east,north
CITY_NAME=sanaa
BBOX=44.023938,15.161991,44.399674,15.642149
GEOFABRIK_URL_PATH=/asia/yemen-latest.osm.pbf
