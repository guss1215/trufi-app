# City name (used for input/output filenames). Must match the file in
# ../pbf-yemen-sanaa/out/${CITY_NAME}.osm.pbf
CITY_NAME=sanaa

# Zoom levels. 14 is upstream's recommendation for transit apps and keeps the
# bundled tile set small (~6 MB for Sana'a). 15 gives finer detail at ~4x size.
MAX_ZOOM=14
MIN_ZOOM=0

# Java heap for planetiler.
JAVA_MEMORY=4g

# Processing threads.
THREADS=4
